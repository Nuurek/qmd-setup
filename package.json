{
  "name": "qmd-setup",
  "version": "1.0.0",
  "description": "Manage qmd collections, launchd, and Claude Code integration",
  "private": true,
  "type": "module",
  "bin": {
    "qmd-setup": "dist/setup.js"
  },
  "scripts": {
    "build": "tsc",
    "setup": "tsc && node dist/setup.js",
    "test": "tsc && node --experimental-test-module-mocks --test dist/*.test.js",
    "lint": "biome check",
    "format": "biome check --write",
    "prepare": "git config core.hooksPath .githooks"
  },
  "lint-staged": {
    "*.{ts,json}": "biome check --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "mustache": "^4.2.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/mustache": "^4.2.6",
    "@types/node": "^22.0.0",
    "lint-staged": "^16.2.7",
    "typescript": "^5.7.0"
  }
}
